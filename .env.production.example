# ====== 数据库 ======
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=erp_user
DB_PASS=CHANGE_ME_to_32char_random
DB_NAME=fengshengda_erp

# ====== JWT ======
# 生产必须改 32+ 位随机串（用 `openssl rand -hex 32` 生成）
JWT_SECRET=CHANGE_ME_to_32char_random
JWT_EXPIRES_IN=8h

# ====== CORS 白名单（逗号分隔）======
CORS_ORIGINS=https://erp.example.com,http://localhost:5173

# ====== 文件上传 ======
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=20

# ====== 限流（每分钟/每 IP）======
THROTTLE_LIMIT=60

# ====== Sentry（可选）======
SENTRY_DSN=

# ====== 日志 ======
LOG_LEVEL=info
NODE_ENV=production
